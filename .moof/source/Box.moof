(def Box { Object
  value: nil
  get: (self)
    (%dot self (quote value))
  describe: (self)
    (str "<Box " (%dot self (quote value)) ">")
})

(handle! Box ["set:" toSymbol] (lambda (self v) (<- (%dot self (quote value)) v) self))

(handle! Box ["update:" toSymbol] (lambda (self f) (<- (%dot self (quote value)) (f (%dot self (quote value)))) self))
