; core.moof — tests for the core language

(def core-tests (suite "core"
  (test "integer add" [3 + 4] 7)
  (test "integer sub" [10 - 3] 7)
  (test "integer mul" [3 * 4] 12)
  (test "integer div" [10 / 2] 5)
  (test "integer mod" [10 % 3] 1)
  (test "integer negate" [5 negate] -5)
  (test "integer compare" [3 < 4] true)
  (test "integer equal" [3 = 3] true)

  (test "div by zero" [[1 / 0] ok?] false)
  (test "err is not ok" [[1 / 0] ok?] false)

  (test "string concat" ["hello" ++ " world"] "hello world")
  (test "string length" ["hello" length] 5)
  (test "string reverse" ["abc" reverse] "cba")
  (test "string repeat" ["ab" repeat: 3] "ababab")

  (test "list map" [(list 1 2 3) map: |x| [x * 2]] (list 2 4 6))
  (test "list fold" [(list 1 2 3) fold: 0 with: |a x| [a + x]] 6)
  (test "list select" [(list 1 2 3 4 5) select: |x| [x > 3]] (list 4 5))
  (test "list reverse" [(list 1 2 3) reverse] (list 3 2 1))
  (test "list take" [(list 1 2 3 4 5) take: 3] (list 1 2 3))
  (test "list drop" [(list 1 2 3 4 5) drop: 2] (list 3 4 5))

  (test "range" (range 5) (list 0 1 2 3 4))
  (test "range map" [[1 to: 3] map: |x| [x * x]] (list 1 4 9))

  (test "with:" [[{ x: 1 y: 2 } with: { x: 10 }] slotAt: (quote x)] 10)
  (test "with: immutable" (let ((p { x: 1 })) [[p with: { x: 99 }] slotAt: (quote x)]) 99)

  (test "some" [(Some 5) some?] true)
  (test "none" [None some?] false)
  (test "some then" [(Some 5) then: |x| [x + 1]] 6)
  (test "none then" [None then: |x| [x + 1]] None)
  (test "some or" [(Some 5) or: 0] 5)
  (test "none or" [None or: 0] 0)

  (test "ok then" [{ Ok value: 5 } then: |x| [x + 1]] 6)
  (test "err short-circuit" [(err "nope") then: |x| [x + 1]] (err "nope"))
  (test "err recover" [(err "nope") recover: |msg| (str "got: " msg)] "got: nope")

  (test "nested capture" (let ((f (fn (a) (fn (b) (fn (c) [[a + b] + c])))))
    (((f 100) 20) 3)) 123)

  (test "do notation" (do (x <- { Ok value: 10 }) (y <- { Ok value: 20 }) [x + y]) 30)
  (test "do err" (do (x <- (err "fail")) [x + 1]) (err "fail"))
  (test "do option" (do (x <- (Some 10)) (y <- (Some 20)) [x + y]) 30)
  (test "do option none" (do (x <- (Some 10)) (y <- None) [x + y]) None)

  (test "update delta" [(update { count: 5 } 42) delta] { count: 5 })
  (test "update reply" [(update { count: 5 } 42) reply] 42)

  (test "str variadic" (str "a" "b" "c") "abc")
  (test "pow" [2 pow: 10] 1024)
  (test "gcd" [12 gcd: 8] 4)
  (test "digits" [42 digits] (list 4 2))
  (test "factorial" [5 factorial] 120)

  ; ── wave 1.3: prototype-as-type identity ─────────────

  (test "typeName int"    [42 typeName]         (quote Integer))
  (test "typeName float"  [3.14 typeName]       (quote Float))
  (test "typeName string" ["hi" typeName]       (quote String))
  (test "typeName nil"    [nil typeName]        (quote Nil))
  (test "typeName bool"   [true typeName]       (quote Boolean))
  (test "typeName cons"   [(list 1 2) typeName] (quote Cons))
  (test "typeName some"   [(Some 42) typeName]  (quote Some))
  (test "typeName none"   [None typeName]       (quote None))
  (test "typeName ok"     [{ Ok value: 1 } typeName] (quote Ok))
  (test "typeName err"    [(err "x") typeName]  (quote Err))

  ; prototype chain reflects real inheritance
  (test "int is Number"      [42 is: Number]        true)
  (test "float is Number"    [3.14 is: Number]      true)
  (test "Some is Option"     [(Some 42) is: Option] true)
  (test "None is Option"     [None is: Option]      true)
  (test "Option sealed"      [Option sealed?]       true)
  (test "Option variants"    [[Option variants] count] 2)

  ; prototypes list includes self, parents up to Object
  (test "42 chain length"    [[42 prototypes] count] 4)  ; 42 Integer Number Object
  (test "Some chain has Option" [[(Some 1) prototypes] includes: Option] true)

  ; shape returns structural record
  (test "shape has typeName" [[(Some 1) shape] slotAt: (quote typeName)] (quote Some))

  ; protocol conformers registry
  (test "Chainable has conformers"    [[Chainable conformers] empty?]  false)
  (test "Chainable includes Ok"       (member? Ok   [Chainable conformers]) true)
  (test "Chainable includes Cons"     (member? Cons [Chainable conformers]) true)
  (test "Comparable includes Number"  (member? Number [Comparable conformers]) true)
  (test "Numeric includes Number"     (member? Number [Numeric conformers])   true)

  ; Cons equal: short-circuits on identity (so proto == proto works)
  (test "Cons equal self"  [Cons equal: Cons] true)
  (test "list equal list"  [(list 1 2 3) equal: (list 1 2 3)] true)
  (test "list equal diff"  [(list 1 2)   equal: (list 1 2 3)] false)
  (test "conform is deduped"
    (do
      (conform Cons Chainable)   ; already there
      (conform Cons Chainable)   ; should not duplicate
      [[Chainable conformers] count: |t| [t identical: Cons]])
    1)

  ; Buildable: map / select / reject preserve type
  (test "Table map preserves type"    [[#[1 2 3] map: |x| [x * 2]] typeName]    (quote Table))
  (test "Table map content"           [#[1 2 3] map: |x| [x * 2]]               #[2 4 6])
  (test "String map preserves type"   [["abc" map: |c| [c ++ "!"]] typeName]    (quote String))
  (test "String map content"          ["abc" map: |c| [c ++ "!"]]               "a!b!c!")
  (test "Table select preserves type" [[#[1 2 3 4] select: |x| [x > 2]] typeName] (quote Table))
  (test "Table select content"        [#[1 2 3 4] select: |x| [x > 2]]          #[3 4])
  (test "Table reject content"        [#[1 2 3 4] reject: |x| [x > 2]]          #[1 2])
  (test "String reject preserves type" [["abcde" reject: |c| [c equal: "c"]] typeName] (quote String))
  (test "Cons map still returns Cons" [[(list 1 2 3) map: |x| [x * 2]] typeName] (quote Cons))

  ; ── wave 1.5: Set ────────────────────────────────────
  (test "Set dedup"           [(Set 1 2 3 2 1) size]                3)
  (test "Set typeName"        [(Set 1 2 3) typeName]                (quote Set))
  (test "Set includes"        [(Set 1 2 3) includes: 2]             true)
  (test "Set excludes"        [(Set 1 2 3) includes: 4]             false)
  (test "Set add new"         [[(Set 1 2) add: 3] size]             3)
  (test "Set add dup"         [[(Set 1 2 3) add: 2] size]           3)
  (test "Set remove"          [[(Set 1 2 3) remove: 2] size]        2)
  (test "Set union size"      [[(Set 1 2) union: (Set 2 3)] size]   3)
  (test "Set intersection"    [[(Set 1 2 3) intersection: (Set 3 4 5)] size]   1)
  (test "Set difference"      [[(Set 1 2 3) difference: (Set 3 4 5)] size]    2)
  (test "Set subset?"         [(Set 1 2) subset?: (Set 1 2 3)]      true)
  (test "Set not subset?"     [(Set 1 4) subset?: (Set 1 2 3)]      false)
  (test "Set disjoint?"       [(Set 1 2) disjoint?: (Set 3 4)]      true)
  (test "Set not disjoint?"   [(Set 1 2) disjoint?: (Set 2 3)]      false)
  (test "Set empty?"          [(Set) empty?]                       true)

  ; Buildable for Set: map/select preserve type
  (test "Set map preserves type" [[(Set 1 2 3) map: |x| [x * 2]] typeName] (quote Set))
  (test "Set select preserves type" [[(Set 1 2 3 4) select: |x| [x > 2]] typeName] (quote Set))

  ; toSet constructors
  (test "Cons toSet"          [[(list 1 2 3 2 1) toSet] size]       3)
  (test "Table toSet"         [[#[1 2 3 2 1] toSet] size]           3)

  ; structural equality
  (test "Set equal same"      [(Set 1 2 3) equal: (Set 3 2 1)]      true)
  (test "Set equal diff"      [(Set 1 2 3) equal: (Set 1 2)]        false)

  ; rendering
  (test "Set describe"        [(Set 1 2 3) describe]                "{1, 2, 3}")

  ; Iterable methods via each: — all work for free
  (test "Set sum"             [(Set 1 2 3) sum]                     6)
  (test "Set any"             [(Set 1 2 3) any: |x| [x > 2]]        true)
  (test "Set all"             [(Set 2 4 6) all: |x| [x even?]]      true)

  ; ── wave 1.6: full type-preservation coverage ────────

  ; take / drop on Table and String
  (test "Table take preserves"  [[#[1 2 3 4 5] take: 3] typeName]   (quote Table))
  (test "Table take content"    [#[1 2 3 4 5] take: 3]              #[1 2 3])
  (test "Table drop preserves"  [[#[1 2 3 4 5] drop: 2] typeName]   (quote Table))
  (test "Table drop content"    [#[1 2 3 4 5] drop: 2]              #[3 4 5])
  (test "String take"           ["hello" take: 3]                  "hel")
  (test "String drop"           ["hello" drop: 2]                  "llo")
  (test "String take preserves" [["hello" take: 3] typeName]       (quote String))
  (test "Set take preserves"    [[(Set 1 2 3 4) take: 2] typeName] (quote Set))

  ; takeWhile / dropWhile
  (test "Table takeWhile"       [#[1 2 3 4 5] takeWhile: |x| [x < 4]] #[1 2 3])
  (test "Table dropWhile"       [#[1 2 3 4 5] dropWhile: |x| [x < 3]] #[3 4 5])
  (test "String takeWhile"      ["aaaBBB" takeWhile: |c| [c equal: "a"]] "aaa")

  ; reverse on Table
  (test "Table reverse preserves" [[#[1 2 3] reverse] typeName]    (quote Table))
  (test "Table reverse content"   [#[1 2 3] reverse]               #[3 2 1])

  ; distinct (and the broken-forever bug fix)
  (test "Cons distinct"         [(list 1 2 2 3 3 1) distinct]      (list 1 2 3))
  (test "Table distinct"        [#[1 2 2 3 3] distinct]            #[1 2 3])
  (test "String distinct"       ["aabbcca" distinct]               "abc")
  (test "Set distinct is self"  [(Set 1 2 3) distinct]             (Set 1 2 3))

  ; member? uses equal: (structural) now — String dedup works
  (test "member? on strings"   (member? "b" (list "a" "b" "c"))   true)
))

[console println: (report core-tests)]
