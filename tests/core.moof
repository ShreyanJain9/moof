; core.moof — tests for the core language

(def core-tests (suite "core"
  (test "integer add" [3 + 4] 7)
  (test "integer sub" [10 - 3] 7)
  (test "integer mul" [3 * 4] 12)
  (test "integer div" [10 / 2] 5)
  (test "integer mod" [10 % 3] 1)
  (test "integer negate" [5 negate] -5)
  (test "integer compare" [3 < 4] true)
  (test "integer equal" [3 = 3] true)

  (test "div by zero" [[1 / 0] ok?] false)
  (test "err is not ok" [[1 / 0] ok?] false)

  (test "string concat" ["hello" ++ " world"] "hello world")
  (test "string length" ["hello" length] 5)
  (test "string reverse" ["abc" reverse] "cba")
  (test "string repeat" ["ab" repeat: 3] "ababab")

  (test "list map" [(list 1 2 3) map: |x| [x * 2]] (list 2 4 6))
  (test "list fold" [(list 1 2 3) fold: 0 with: |a x| [a + x]] 6)
  (test "list select" [(list 1 2 3 4 5) select: |x| [x > 3]] (list 4 5))
  (test "list reverse" [(list 1 2 3) reverse] (list 3 2 1))
  (test "list take" [(list 1 2 3 4 5) take: 3] (list 1 2 3))
  (test "list drop" [(list 1 2 3 4 5) drop: 2] (list 3 4 5))

  (test "range" (range 5) (list 0 1 2 3 4))
  (test "range map" [[1 to: 3] map: |x| [x * x]] (list 1 4 9))

  (test "with:" [[{ x: 1 y: 2 } with: { x: 10 }] slotAt: (quote x)] 10)
  (test "with: immutable" (let ((p { x: 1 })) [[p with: { x: 99 }] slotAt: (quote x)]) 99)

  (test "some" [(Some 5) some?] true)
  (test "none" [None some?] false)
  (test "some then" [(Some 5) then: |x| [x + 1]] 6)
  (test "none then" [None then: |x| [x + 1]] None)
  (test "some or" [(Some 5) or: 0] 5)
  (test "none or" [None or: 0] 0)

  (test "ok then" [{ Ok value: 5 } then: |x| [x + 1]] 6)
  (test "err short-circuit" [(err "nope") then: |x| [x + 1]] (err "nope"))
  (test "err recover" [(err "nope") recover: |msg| (str "got: " msg)] "got: nope")

  (test "nested capture" (let ((f (fn (a) (fn (b) (fn (c) [[a + b] + c])))))
    (((f 100) 20) 3)) 123)

  (test "do notation" (do (x <- { Ok value: 10 }) (y <- { Ok value: 20 }) [x + y]) 30)
  (test "do err" (do (x <- (err "fail")) [x + 1]) (err "fail"))
  (test "do option" (do (x <- (Some 10)) (y <- (Some 20)) [x + y]) 30)
  (test "do option none" (do (x <- (Some 10)) (y <- None) [x + y]) None)

  (test "update delta" [(update { count: 5 } 42) delta] { count: 5 })
  (test "update reply" [(update { count: 5 } 42) reply] 42)

  (test "str variadic" (str "a" "b" "c") "abc")
  (test "pow" [2 pow: 10] 1024)
  (test "gcd" [12 gcd: 8] 4)
  (test "digits" [42 digits] (list 4 2))
  (test "factorial" [5 factorial] 120)

  ; ── wave 1.3: prototype-as-type identity ─────────────

  (test "typeName int"    [42 typeName]         (quote Integer))
  (test "typeName float"  [3.14 typeName]       (quote Float))
  (test "typeName string" ["hi" typeName]       (quote String))
  (test "typeName nil"    [nil typeName]        (quote Nil))
  (test "typeName bool"   [true typeName]       (quote Boolean))
  (test "typeName cons"   [(list 1 2) typeName] (quote Cons))
  (test "typeName some"   [(Some 42) typeName]  (quote Some))
  (test "typeName none"   [None typeName]       (quote None))
  (test "typeName ok"     [{ Ok value: 1 } typeName] (quote Ok))
  (test "typeName err"    [(err "x") typeName]  (quote Err))

  ; prototype chain reflects real inheritance
  (test "int is Number"      [42 is: Number]        true)
  (test "float is Number"    [3.14 is: Number]      true)
  (test "Some is Option"     [(Some 42) is: Option] true)
  (test "None is Option"     [None is: Option]      true)
  (test "Option sealed"      [Option sealed?]       true)
  (test "Option variants"    [[Option variants] count] 2)

  ; prototypes list includes self, parents up to Object
  (test "42 chain length"    [[42 prototypes] count] 4)  ; 42 Integer Number Object
  (test "Some chain has Option" [[(Some 1) prototypes] includes: Option] true)

  ; shape returns structural record
  (test "shape has typeName" [[(Some 1) shape] slotAt: (quote typeName)] (quote Some))

  ; conformance is structural, not a stored registry. a type
  ; conforms to a protocol iff it responds to every required
  ; selector — no list of conformers is maintained.

  ; Cons equal: short-circuits on identity (so proto == proto works)
  (test "Cons equal self"  [Cons equal: Cons] true)
  (test "list equal list"  [(list 1 2 3) equal: (list 1 2 3)] true)
  (test "list equal diff"  [(list 1 2)   equal: (list 1 2 3)] false)

  ; Buildable: map / select / reject preserve type
  (test "Table map preserves type"    [[#[1 2 3] map: |x| [x * 2]] typeName]    (quote Table))
  (test "Table map content"           [#[1 2 3] map: |x| [x * 2]]               #[2 4 6])
  (test "String map preserves type"   [["abc" map: |c| [c ++ "!"]] typeName]    (quote String))
  (test "String map content"          ["abc" map: |c| [c ++ "!"]]               "a!b!c!")
  (test "Table select preserves type" [[#[1 2 3 4] select: |x| [x > 2]] typeName] (quote Table))
  (test "Table select content"        [#[1 2 3 4] select: |x| [x > 2]]          #[3 4])
  (test "Table reject content"        [#[1 2 3 4] reject: |x| [x > 2]]          #[1 2])
  (test "String reject preserves type" [["abcde" reject: |c| [c equal: "c"]] typeName] (quote String))
  (test "Cons map still returns Cons" [[(list 1 2 3) map: |x| [x * 2]] typeName] (quote Cons))

  ; ── wave 1.5: Set ────────────────────────────────────
  (test "Set dedup"           [(Set 1 2 3 2 1) size]                3)
  (test "Set typeName"        [(Set 1 2 3) typeName]                (quote Set))
  (test "Set includes"        [(Set 1 2 3) includes: 2]             true)
  (test "Set excludes"        [(Set 1 2 3) includes: 4]             false)
  (test "Set add new"         [[(Set 1 2) add: 3] size]             3)
  (test "Set add dup"         [[(Set 1 2 3) add: 2] size]           3)
  (test "Set remove"          [[(Set 1 2 3) remove: 2] size]        2)
  (test "Set union size"      [[(Set 1 2) union: (Set 2 3)] size]   3)
  (test "Set intersection"    [[(Set 1 2 3) intersection: (Set 3 4 5)] size]   1)
  (test "Set difference"      [[(Set 1 2 3) difference: (Set 3 4 5)] size]    2)
  (test "Set subset?"         [(Set 1 2) subset?: (Set 1 2 3)]      true)
  (test "Set not subset?"     [(Set 1 4) subset?: (Set 1 2 3)]      false)
  (test "Set disjoint?"       [(Set 1 2) disjoint?: (Set 3 4)]      true)
  (test "Set not disjoint?"   [(Set 1 2) disjoint?: (Set 2 3)]      false)
  (test "Set empty?"          [(Set) empty?]                       true)

  ; Buildable for Set: map/select preserve type
  (test "Set map preserves type" [[(Set 1 2 3) map: |x| [x * 2]] typeName] (quote Set))
  (test "Set select preserves type" [[(Set 1 2 3 4) select: |x| [x > 2]] typeName] (quote Set))

  ; toSet constructors
  (test "Cons toSet"          [[(list 1 2 3 2 1) toSet] size]       3)
  (test "Table toSet"         [[#[1 2 3 2 1] toSet] size]           3)

  ; structural equality
  (test "Set equal same"      [(Set 1 2 3) equal: (Set 3 2 1)]      true)
  (test "Set equal diff"      [(Set 1 2 3) equal: (Set 1 2)]        false)

  ; rendering
  (test "Set describe"        [(Set 1 2 3) describe]                "{1, 2, 3}")

  ; Iterable methods via each: — all work for free
  (test "Set sum"             [(Set 1 2 3) sum]                     6)
  (test "Set any"             [(Set 1 2 3) any: |x| [x > 2]]        true)
  (test "Set all"             [(Set 2 4 6) all: |x| [x even?]]      true)

  ; ── wave 1.6: full type-preservation coverage ────────

  ; take / drop on Table and String
  (test "Table take preserves"  [[#[1 2 3 4 5] take: 3] typeName]   (quote Table))
  (test "Table take content"    [#[1 2 3 4 5] take: 3]              #[1 2 3])
  (test "Table drop preserves"  [[#[1 2 3 4 5] drop: 2] typeName]   (quote Table))
  (test "Table drop content"    [#[1 2 3 4 5] drop: 2]              #[3 4 5])
  (test "String take"           ["hello" take: 3]                  "hel")
  (test "String drop"           ["hello" drop: 2]                  "llo")
  (test "String take preserves" [["hello" take: 3] typeName]       (quote String))
  (test "Set take preserves"    [[(Set 1 2 3 4) take: 2] typeName] (quote Set))

  ; takeWhile / dropWhile
  (test "Table takeWhile"       [#[1 2 3 4 5] takeWhile: |x| [x < 4]] #[1 2 3])
  (test "Table dropWhile"       [#[1 2 3 4 5] dropWhile: |x| [x < 3]] #[3 4 5])
  (test "String takeWhile"      ["aaaBBB" takeWhile: |c| [c equal: "a"]] "aaa")

  ; reverse on Table
  (test "Table reverse preserves" [[#[1 2 3] reverse] typeName]    (quote Table))
  (test "Table reverse content"   [#[1 2 3] reverse]               #[3 2 1])

  ; distinct (and the broken-forever bug fix)
  (test "Cons distinct"         [(list 1 2 2 3 3 1) distinct]      (list 1 2 3))
  (test "Table distinct"        [#[1 2 2 3 3] distinct]            #[1 2 3])
  (test "String distinct"       ["aabbcca" distinct]               "abc")
  (test "Set distinct is self"  [(Set 1 2 3) distinct]             (Set 1 2 3))

  ; member? uses equal: (structural) now — String dedup works
  (test "member? on strings"   (member? "b" (list "a" "b" "c"))   true)

  ; ── wave 3.0: Hashable — content hashing substrate ───
  ;
  ; invariant: structurally-equal values hash equal, and the
  ; hash is deterministic across processes (no randomization).

  ; primitives hash via their NaN-boxed bit pattern so distinct
  ; values never collide across types (no more Integer 1 = Boolean true).
  (test "int hash deterministic" (eq [42 hash] [42 hash])             true)
  (test "bool diff"          (not (eq [true hash] [false hash]))   true)
  (test "int vs bool"        (not (eq [1 hash] [true hash]))       true)
  (test "int vs nil"         (not (eq [0 hash] [nil hash]))        true)
  (test "int vs float"       (not (eq [0 hash] [0.0 hash]))        true)
  (test "int 2 vs false"     (not (eq [2 hash] [false hash]))      true)

  ; deterministic — same hash every call
  (test "string det"         (eq ["hi" hash] ["hi" hash])         true)
  (test "list det"           (eq [(list 1 2 3) hash] [(list 1 2 3) hash]) true)

  ; structurally equal → equal hash
  (test "equal strings"      (eq ["hi" hash] ["hi" hash])         true)
  (test "equal tables"       (eq [#[1 2 3] hash] [#[1 2 3] hash]) true)

  ; different values → different hashes
  (test "diff ints"          (not (eq [42 hash] [43 hash]))       true)
  (test "diff lists"         (not (eq [(list 1 2) hash] [(list 1 2 3) hash])) true)

  ; Sets hash order-independently
  (test "set order indep"    (eq [(Set 1 2 3) hash] [(Set 3 1 2) hash]) true)

  ; typeName factors in
  (test "some vs none diff"  (not (eq [(Some nil) hash] [None hash])) true)
  (test "some stable"        (eq [(Some 42) hash] [(Some 42) hash]) true)
  (test "some diff value"    (not (eq [(Some 42) hash] [(Some 43) hash])) true)

  ; anonymous objects hash structurally
  (test "anon obj stable"    (eq [{ x: 3 y: 4 } hash] [{ x: 3 y: 4 } hash]) true)

  ; ── wave 3.1: transducers — one pipeline, any substrate ──

  ; stateless
  (test "map-xf"       [(list 1 2 3) transduce: (map-xf |x| [x * 2])]     (list 2 4 6))
  (test "filter-xf"    [(list 1 2 3 4) transduce: (filter-xf |x| [x > 2])] (list 3 4))
  (test "remove-xf"    [(list 1 2 3 4) transduce: (remove-xf |x| [x > 2])] (list 1 2))

  ; stateful
  (test "take-xf"      [(list 1 2 3 4 5) transduce: (take-xf 3)]          (list 1 2 3))
  (test "drop-xf"      [(list 1 2 3 4 5) transduce: (drop-xf 2)]          (list 3 4 5))
  (test "take-while"   [(list 1 2 3 4 5) transduce: (take-while-xf |x| [x < 3])] (list 1 2))
  (test "drop-while"   [(list 1 2 3 4 5) transduce: (drop-while-xf |x| [x < 3])] (list 3 4 5))
  (test "distinct-xf"  [(list 1 2 2 3 3 1) transduce: (distinct-xf)]      (list 1 2 3))

  ; chain — compose several transducers into one pipeline
  (test "chain map+filter"
    [(list 1 2 3 4 5) transduce: (chain (map-xf |x| [x * 2]) (filter-xf |x| [x > 4]))]
    (list 6 8 10))
  (test "chain map+filter+take"
    [(list 1 2 3 4 5) transduce: (chain (map-xf |x| [x * 2]) (filter-xf |x| [x > 4]) (take-xf 2))]
    (list 6 8))

  ; type preservation via transduce: — same substrate transducer,
  ; different input collection types, output matches input
  (test "xf preserves Table"  [[#[1 2 3] transduce: (map-xf |x| [x * 10])] typeName] (quote Table))
  (test "xf Table content"    [#[1 2 3] transduce: (map-xf |x| [x * 10])] #[10 20 30])
  (test "xf preserves Set"    [[(Set 1 2 3) transduce: (map-xf |x| [x * 10])] typeName] (quote Set))

  ; into:via: — target container type explicitly
  (test "into: Table via map" [(list 1 2 3) into: #[] via: (map-xf |x| [x * 10])] #[10 20 30])
  (test "into: Set via map"   [[(list 1 1 2 2 3) into: (Set) via: (map-xf |x| [x * 2])] size] 3)

  ; transduce:init:with: — full manual: user provides init and rf
  (test "transduce sum"
    [(list 1 2 3 4 5) transduce: (map-xf |x| [x * 2]) init: 0 with: |a x| [a + x]]
    30)

  ; ── wave 3.2: Stream — lazy Iterable via next ────────
  ; all tests bounded: take:/toList on finite sources only.
  ; infinite streams are never materialized without a take: guard.

  (test "stream-range to list"  [(stream-range 0 5) toList]    (list 0 1 2 3 4))
  (test "stream-range typeName" [(stream-range 0 5) typeName]  (quote Stream))
  (test "stream-iterate take"   [(stream-iterate 0 |x| [x + 1]) take: 5] (list 0 1 2 3 4))
  (test "stream-iterate pow"    [(stream-iterate 1 |x| [x * 2]) take: 5] (list 1 2 4 8 16))
  (test "stream-from take"      [(stream-from (list 10 20 30)) take: 2]  (list 10 20))
  (test "stream-from toList"    [(stream-from (list 1 2 3)) toList]      (list 1 2 3))
  (test "stream-repeat take"    [(stream-repeat 7) take: 3]              (list 7 7 7))
  (test "stream-of"             [(stream-of 1 2 3) toList]               (list 1 2 3))

  ; Iterable methods via each: — sum/count/etc. on bounded streams
  (test "stream sum"            [(stream-range 1 5) sum]                 10)
  (test "stream count"          [(stream-range 0 5) count]               5)

  ; stateful nature — each stream iterates once, state advances.
  ; pure streams: the same stream always yields the same prefix.
  ; to advance, call [rest] or [drop: n] — both return a fresh
  ; stream without mutating the original.
  (test "stream is persistent"
    (let ((s (stream-iterate 0 |x| [x + 1])))
      (let ((_ [s take: 3])) [s take: 2]))
    (list 0 1))

  (test "stream drop advances"
    [[(stream-iterate 0 |x| [x + 1]) drop: 3] take: 2]
    (list 3 4))

  (test "stream rest advances"
    [[(stream-iterate 0 |x| [x + 1]) rest] take: 2]
    (list 1 2))

  ; transducers on finite streams work — [stream transduce: xf]
  ; goes via Stream's type-preserving into:via: path? actually
  ; transduce: uses builder which on Stream emptyKindred... we
  ; haven't defined that. for now test with toList+transduce.
  (test "stream through transducer"
    [[(stream-range 0 10) toList] transduce: (map-xf |x| [x * x])]
    (list 0 1 4 9 16 25 36 49 64 81))

  ; ── wave 3.4: Inspector — moldable views ────────────
  ;
  ; every value has [inspect] returning an Inspector with
  ; multiple named aspects. each type adds its own.

  (test "int has inspector"    [[42 inspect] typeName]                  (quote Inspector))
  (test "int aspect names"     (member? (quote describe) [[42 inspect] aspectNames]) true)
  (test "int describe aspect"  [[42 inspect] render: (quote describe)]  "42")
  (test "int shape aspect not nil" [[[42 inspect] render: (quote shape)] is: Nil] false)

  ; per-type aspects
  (test "cons has list aspect" (member? (quote list) [[(list 1 2 3) inspect] aspectNames]) true)
  (test "cons summary"         [[(list 1 2 3) inspect] render: (quote summary)] "Cons: 3 elements, first = 1")
  (test "set summary"          [[(Set 1 2 3) inspect] render: (quote summary)] "Set: 3 elements")
  (test "table has grid"       (member? (quote grid) [[#[1 2 3] inspect] aspectNames]) true)

  ; Protocol inspector — queryable protocol surface
  (test "protocol has requires aspect"
    (member? (quote requires) [[Chainable inspect] aspectNames]) true)

  ; default aspect falls through to describe
  (test "unknown aspect nil"   [[42 inspect] render: (quote nope)]      nil)

  ; ── wave 3.5: Queryable — queries as first-class values ──
  ;
  ; queries are DATA — built by composition, inspected before
  ; running, composable across calls. [q run] executes.

  (test "empty query runs"     [(from (list 1 2 3)) run]               (list 1 2 3))
  (test "where filters"        [[(from (list 1 2 3 4 5)) where: |x| [x > 2]] run] (list 3 4 5))
  (test "take limits"          [[(from (list 1 2 3 4 5)) take: 2] run]  (list 1 2))
  (test "drop skips"           [[(from (list 1 2 3 4 5)) drop: 2] run]  (list 3 4 5))
  (test "map transforms"       [[(from (list 1 2 3)) map: |x| [x * 2]] run] (list 2 4 6))
  (test "distinct dedups"      [[(from (list 1 2 2 3 3 1)) distinct] run] (list 1 2 3))

  (test "where + take compose"
    [[[(from (list 1 2 3 4 5)) where: |x| [x > 2]] take: 2] run]
    (list 3 4))

  (test "reject"               [[(from (list 1 2 3 4)) reject: |x| [x > 2]] run] (list 1 2))

  (test "count terminal"       [[(from (list 1 2 3 4 5)) where: |x| [x > 2]] count] 3)
  (test "sum terminal"         [[(from (list 1 2 3 4 5)) where: |x| [x > 2]] sum]   12)

  ; queries are Query-typed values
  (test "query typeName"       [(from (list)) typeName]                  (quote Query))

  ; Inspector aspects for Query
  (test "query has steps aspect"
    (member? (quote steps) [[(from (list)) inspect] aspectNames]) true)

  ; building doesn't mutate — each step returns a new Query
  (test "query immutable"
    (let ((q1 (from (list 1 2 3))))
      (let ((q2 [q1 where: |x| [x > 1]]))
        [q1 count]))
    3)

  ; [obj queried] — method shortcut for (from obj)
  (test "queried shortcut"     [[[(list 1 2 3) queried] take: 2] run]    (list 1 2))

  ; ── wave 4.1: GC — introspection only (gc runs at REPL safepoints)
  ;
  ; actual [Vat gc] can't run mid-expression — VM frames hold live
  ; refs the heap can't see. [Vat requestGc] sets a flag that the
  ; REPL loop drains between turns. inside a test suite the flag
  ; wouldn't fire until the whole suite finishes, so we just verify
  ; the introspection hooks here; correctness tests live in Rust.

  (test "heapSize is int" [[Vat heapSize] typeName] (quote Integer))
  (test "liveCount <= heapSize" [[Vat liveCount] <= [Vat heapSize]] true)
  (test "requestGc sets flag" [Vat requestGc] nil)

  ; ── wave 4.4: JSON — universal interchange ──────────
  ;
  ; json → moof type map: null → nil, true/false → Boolean,
  ; number → Integer or Float, string → String, array → Cons,
  ; object → Table (keyed part).

  (test "json null"      [json parse: "null"]     nil)
  (test "json true"      [json parse: "true"]     true)
  (test "json false"     [json parse: "false"]    false)
  (test "json int"       [json parse: "42"]       42)
  (test "json float"     [[json parse: "3.14"] typeName]    (quote Float))
  (test "json string"    [json parse: "\"hi\""]   "hi")
  (test "json array"     [json parse: "[1,2,3]"]  (list 1 2 3))

  ; parse errors
  (test "json bad parse" [[json parse: "nope"] ok?]          false)

  ; serialize the common cases
  (test "serialize int"    [json serialize: 42]            "42")
  (test "serialize string" [json serialize: "hi"]          "\"hi\"")
  (test "serialize nil"    [json serialize: nil]           "null")
  (test "serialize list"   [json serialize: (list 1 2 3)]  "[1,2,3]")
  (test "serialize bool"   [json serialize: true]          "true")

  ; round-trip
  (test "round-trip int"   [json parse: [json serialize: 42]]           42)
  (test "round-trip list"  [json parse: [json serialize: (list 1 2 3)]] (list 1 2 3))

  ; ── wave 4.5: Reference + File as value ────────────

  (test "File type"          [(File "a.txt") typeName]       (quote File))
  (test "File address"       [(File "a.txt") address]        "a.txt")
  (test "File describe"      [(File "x") describe]           "<File x>")

  ; Reference conformance is structural — File satisfies the
  ; protocol by implementing its required selectors, not by
  ; being in Reference's prototype chain.
  (test "File is not Reference via chain" [(File "/tmp/x") is: Reference] false)

  ; ── Atom + Signal — reactivity substrate ────────────
  ;
  ; Atom and Signal are real server vats now. every read returns
  ; an Act; do-chains await them. state mutation happens only via
  ; Update values the scheduler applies between messages.

  (test "atom get"
    (do (a <- (Atom 10)) [a get])
    10)

  (test "atom swap"
    (do (a <- (Atom 0))
        (_ <- [a swap: 42])
        [a get])
    42)

  (test "atom update"
    (do (a <- (Atom 5))
        (_ <- [a update: |n| [n * 3]])
        [a get])
    15)

  ; Signal runs in its own vat. the computation closure captures
  ; input FarRefs, migrates via the scheduler's closure walker, and
  ; runs cross-vat. a single-send body like `[a get]` works directly;
  ; pipelines with a post-step chain through the Signal's own then:
  ; handling.
  (test "signal derives"
    (do (a <- (Atom 3))
        (s <- (Signal || [a get] a))
        [s get])
    3)

  ; do-inside-computation works because the compiler now pre-captures
  ; free vars in operative-call args (phase 9 — the vau-opacity fix).
  (test "signal with transform"
    (do (a <- (Atom 3))
        (s <- (Signal || (do (v <- [a get]) [v * 10]) a))
        [s get])
    30)

  ; ── wave 4.8: Bag — multiset ────────────────────────

  (test "bag typeName"   [(Bag "x") typeName]          (quote Bag))
  (test "bag counts"     [(Bag "a" "a" "b") count: "a"] 2)
  (test "bag size"       [(Bag "a" "a" "b") size]       3)
  (test "bag uniqueCount" [(Bag "a" "a" "b") uniqueCount] 2)
  (test "bag absent"     [(Bag "a") count: "z"]         0)
  (test "bag includes"   [(Bag "a") includes: "a"]      true)
  (test "bag add"        [[(Bag "a") add: "a"] count: "a"] 2)
  (test "bag remove dec" [[(Bag "a" "a") remove: "a"] count: "a"] 1)
  (test "bag remove gone" [[(Bag "a") remove: "a"] includes: "a"] false)
  (test "bag equal"      [(Bag "a" "b" "a") equal: (Bag "a" "a" "b")] true)
  (test "bag diff"       [(Bag "a") equal: (Bag "b")] false)
  (test "cons toBag"     [[(list 1 1 2 3 3 3) toBag] count: 3] 3)

  ; signal tests now live in a dedicated file — need careful do-chain
  ; setup with subscriptions that doesn't fit the single-expression
  ; test harness well. for now exercise the core lifecycle here.
  ; (defserver-based Signal correctness is verified interactively
  ; in examples/reactive-demo.moof)

  ; ── wave 4.10: Workspace + Block primitives ──────────

  (test "heading render"    [(Heading "hi") render: (quote text)]      "# hi")
  (test "heading level"     [(Heading 2 "sub") render: (quote text)]   "## sub")
  (test "paragraph render"  [(Paragraph "hello world") render: (quote text)] "hello world")

  (test "workspace empty"
    (do (w <- (Workspace "untitled"))
        [w blockCount])
    0)
  (test "workspace add"
    (do (w <- (Workspace "test"))
        (_ <- [w add: (Paragraph "a")])
        (_ <- [w add: (Paragraph "b")])
        [w blockCount])
    2)
  (test "workspace bind"
    (do (w <- (Workspace "w"))
        (_ <- [w bind: (quote x) to: 42])
        [w lookup: (quote x)])
    42)
))

; report is async now (core-tests is an Act<suite>). run (report core-tests)
; from the REPL and the scheduler drains the chain as the final print fires.
