; definitions.moof — tests for lib/tools/definitions.moof
;
; the analyzer is reusable so we can hit it directly without
; going through (definitions ...). these all return values that
; the test framework checks, so they're hermetic.

(def definitions-tests (suite "definitions"

  ; ── free-vars: leaf cases ──────────────────────────────

  (test "fv: bare ref"
    (free-vars 'x nil)
    (list 'x))

  (test "fv: bound ref"
    (free-vars 'x (list 'x))
    nil)

  (test "fv: special form"
    (free-vars 'if nil)
    nil)

  ; ── free-vars: structural ─────────────────────────────

  (test "fv: send"
    (free-vars '[x + 1] nil)
    (list 'x))

  (test "fv: fn shadows"
    (free-vars '(fn (x) [(g x) + 1]) nil)
    (list 'g))

  (test "fv: vau shadows args + env"
    (free-vars '(vau args $e (g args $e)) nil)
    (list 'g))

  (test "fv: let progressive"
    (free-vars '(let ((a 1) (b (g a))) [a + b]) nil)
    (list 'g))

  (test "fv: quote suppresses"
    (free-vars '(quote (x y z)) nil)
    nil)

  (test "fv: quasiquote with unquote escapes"
    (free-vars '(quasiquote (a b (unquote x))) nil)
    (list 'x))

  (test "fv: nested fn shadows outer"
    (free-vars '(fn (x) (fn (x) [x + 1])) nil)
    nil)

  ; ── produces-of ──────────────────────────────────────

  (test "produces: def" (produces-of '(def foo 42)) 'foo)
  (test "produces: defn" (produces-of '(defn bar (x) x)) 'bar)
  (test "produces: defprotocol" (produces-of '(defprotocol P)) 'P)
  (test "produces: defmethod is extender, not producer"
    (produces-of '(defmethod Object x () 1))
    nil)
  (test "produces: conform is extender, not producer"
    (produces-of '(conform Foo P))
    nil)

  ; ── deps-of ──────────────────────────────────────────

  (test "deps: def value"
    (deps-of '(def quad (fn (x) [(double x) * 2])))
    (list 'double))

  (test "deps: defn body"
    (deps-of '(defn quad (x) [(double x) * 2]))
    (list 'double))

  (test "deps: defmethod treats Proto as a dep"
    [(deps-of '(defmethod Object foo () (helper self)))
      sortBy: |s| [s describe]]
    [(list 'Object 'helper) sortBy: |s| [s describe]])

  (test "deps: defprotocol include"
    (deps-of '(defprotocol C (include S)))
    (list 'S))

  ; ── do-notation binders ──────────────────────────────

  (test "fv: do arrow-bind shadows name"
    (free-vars '(do (x <- some-act) [x + 1]) nil)
    (list 'some-act))

  (test "fv: do nested binds shadow each"
    [(free-vars '(do (x <- a) (y <- b) [x + y]) nil)
      sortBy: |s| [s describe]]
    [(list 'a 'b) sortBy: |s| [s describe]])

  (test "fv: do let-form binds for rest"
    (free-vars '(do (let x (g 1)) [x + 1]) nil)
    (list 'g))

  (test "fv: do yield is just an expression"
    (free-vars '(do (yield (g 1))) nil)
    (list 'g))

  (test "fv: do sequence mode (no binders)"
    [(free-vars '(do a b c) nil)
      sortBy: |s| [s describe]]
    [(list 'a 'b 'c) sortBy: |s| [s describe]])

  ; ── Bundle as a value ────────────────────────────────

  (test "bundle: exposes provides"
    [[(bundle (def x 1) (def y 2)) provides] sortBy: |s| [s describe]]
    [(list 'x 'y) sortBy: |s| [s describe]])

  (test "bundle: exposes requires"
    [(bundle (defn quad (n) [(double n) * 2])) requires]
    (list 'double))

  (test "bundle: count = forms count"
    [(bundle (def a 1) (def b 2) (def c 3)) count]
    3)

  (test "bundle: typeName"
    [(bundle (def a 1)) typeName]
    'Bundle)

  (test "bundle: cycle returns Err"
    [(bundle (defn a () (b)) (defn b () (a))) is: Err]
    true)

  (test "bundle: equal: by structure"
    [(bundle (def x 1) (def y 2)) equal:
       (bundle (def x 1) (def y 2))]
    true)

  (test "bundle: distinct content not equal"
    [(bundle (def x 1)) equal: (bundle (def x 2))]
    false)

  (test "bundle: same content, same content-hash"
    [[(bundle (def x 1) (def y 2)) content-hash]
       equal:
       [(bundle (def x 1) (def y 2)) content-hash]]
    true)

  (test "bundle-merge: provides union"
    [[(bundle-merge (bundle (def a 1)) (bundle (def b 2))) provides]
       sortBy: |s| [s describe]]
    [(list 'a 'b) sortBy: |s| [s describe]])

  (test "bundle-merge: cross-bundle deps satisfied internally"
    [(bundle-merge
        (bundle (defn double (x) [x * 2]))
        (bundle (defn quad (x) [(double x) * 2])))
       requires]
    nil)

  (test "bundle-satisfies?: yes when provider has all consumer needs"
    (bundle-satisfies?
      (bundle (defn double (x) [x * 2]))
      (bundle (defn quad (x) [(double x) * 2])))
    true)

  (test "bundle-satisfies?: no when consumer needs more"
    (bundle-satisfies?
      (bundle (def x 1))
      (bundle (defn f () (g))))
    false)

  ; ── Namespace ────────────────────────────────────────

  (test "namespace: empty count"
    [(Namespace) count]
    0)

  (test "namespace: empty?"
    [(Namespace) empty?]
    true)

  (test "namespace: at:put: + at:"
    [[(Namespace) at: 'k put: 42] at: 'k]
    42)

  (test "namespace: has?:"
    [[(Namespace) at: 'k put: 1] has?: 'k]
    true)

  (test "namespace: missing key returns nil"
    [(Namespace) at: 'absent]
    nil)

  (test "namespace: union prefers other on collision"
    [[[(Namespace) at: 'k put: 1] union:
       [(Namespace) at: 'k put: 2]] at: 'k]
    2)

  (test "namespace: walk: works"
    [[(Namespace) at: 'foo put: 99] walk: "/foo"]
    99)

  (test "bundle materialize: count = provides count"
    [[(bundle (def a 1) (def b 2) (def c 3)) materialize] count]
    3)

  (test "bundle materialize: at: returns the value"
    [[(bundle (def k 99)) materialize] at: 'k]
    99)

))
