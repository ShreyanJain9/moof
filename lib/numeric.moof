; numeric.moof — implement +/-/*/negate, get 5 methods free

(def Numeric (make-protocol "Numeric"
  (list '+ '- '* 'negate)
  #[
    'abs => (fn (self) (if [self negative?] [self negate] self))
    'sign => (fn (self) (if [self positive?] 1 (if [self negative?] -1 0)))
    'zero? => (fn (self) [self = 0])
    'positive? => (fn (self) [self > 0])
    'negative? => (fn (self) [self < 0])
  ]
  nil))

(conform Number Numeric)

; ── Integer-specific ───────────────────────────────────

(defmethod Integer even? () (eq [self % 2] 0))
(defmethod Integer odd? () (not [self even?]))
(defmethod Integer inc () [self + 1])
(defmethod Integer dec () [self - 1])
(alias Integer succ inc)
(alias Integer pred dec)

(defmethod Integer times: (block)
  (let ((i 0)) (while [i < self] (block i) (:= i [i + 1]))))

(defmethod Integer upto:do: (limit block)
  (let ((i self)) (while [i <= limit] (block i) (:= i [i + 1]))))

(defmethod Integer downto:do: (limit block)
  (let ((i self)) (while [i >= limit] (block i) (:= i [i - 1]))))

(defmethod Integer pow: (exp)
  (let ((result 1) (i 0))
    (while [i < exp] (:= result [result * self]) (:= i [i + 1]))
    result))

(defmethod Integer gcd: (other)
  (let ((a [self abs]) (b [other abs]))
    (while (not [b zero?])
      (let ((t b)) (:= b [a % b]) (:= a t)))
    a))

(defmethod Integer lcm: (other)
  (if (or [self zero?] [other zero?]) 0
    [[[self * other] abs] / [self gcd: other]]))

(defmethod Integer digits ()
  (let ((n [self abs]) (result nil))
    (if [n zero?] (list 0)
      (do (while (not [n zero?])
            (:= result (cons [n % 10] result))
            (:= n [n / 10]))
          result))))

(defmethod Integer factorial ()
  (if [self <= 1] 1 [self * [[self dec] factorial]]))

(defmethod Integer toString () [self describe])
