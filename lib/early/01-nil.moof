;; lib/early/01-nil.moof
;;
;; nil's bootstrap primitives (:cons:, :empty?, :proto) are native
;; methods installed by `intrinsics::install`. this file is empty.
;;
;; nil's other methods (length, car, cdr, reverse, append:, map:,
;; filter:, …) live in stdlib/nil.moof as defmethods that load
;; after the macros are available.
