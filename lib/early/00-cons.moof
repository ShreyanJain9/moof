;; lib/early/00-cons.moof
;;
;; Cons primitives (:car, :cdr, :cons:, :empty?, :null?, :nonEmpty?,
;; :reverse) are native methods installed by `intrinsics::install`.
;; this file is intentionally empty.
;;
;; the algorithmic Cons methods (length, map, filter, reduce, take,
;; drop, =, !=, toString, inspect, append:, …) live in stdlib/cons.moof
;; and shadow the rust :reverse with moof recursion when applicable.
