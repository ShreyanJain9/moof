;; lib/mcos/random/random.test.moof — tests for core/random mco.
;;
;; uses raw raise: for failures — no test framework needed.

(def Random [$mco load: "core/random"])
(def $rng [Random new])
[$rng seedFrom: 42]

;; ── determinism from seed ─────────────────────────────────────────

(let ((a [$rng next])
      (b [$rng next])
      (c [$rng next]))
  (if [a != b]
      nil
      (raise: 'test-failure "determinism: first two values should differ"))
  (if [b != c]
      nil
      (raise: 'test-failure "determinism: second and third values should differ")))

;; ── seedFrom: replays sequence ────────────────────────────────────
;; reseed to 42 and capture the first value. reseed again to 42;
;; the first value should be identical.

[$rng seedFrom: 42]
(let ((a [$rng next]))
  [$rng seedFrom: 42]
  (let ((b [$rng next]))
    (if [a = b]
        nil
        (raise: 'test-failure "replay: first value after reseed should match original"))))

;; ── infinite-source meta on proto ────────────────────────────────

(if [[Random metaAt: 'infinite-source] = #true]
    nil
    (raise: 'test-failure "meta: Random should declare infinite-source #true"))

(if [[Random metaAt: 'infinite-source-flavor] = 'generator]
    nil
    (raise: 'test-failure "meta: Random should declare infinite-source-flavor 'generator"))

;; ── take: returns n values ────────────────────────────────────────

[$rng seedFrom: 42]
(let ((stream [$rng take: 5]))
  (if [[stream length] = 5]
      nil
      (raise: 'test-failure "take: should return 5 values")))

;; ── done? always false ────────────────────────────────────────────

(if [[$rng done?] = #false]
    nil
    (raise: 'test-failure "done? should return #false for infinite source"))
