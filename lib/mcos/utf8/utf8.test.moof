;; lib/mcos/utf8/utf8.test.moof — tests for core/utf8 mco.
;;
;; uses raw raise: for failures — no test framework needed.
;;
;; note: the 'utf8-invalid raise path for length: is tested by the
;; integration runner's wasm_mco.rs Rust tests instead.

(def Utf8 [$mco load: "core/utf8"])

;; ── valid?: — ascii is valid utf-8 ─────────────────────────────────

(if [[Utf8 valid?: ["hello" asUtf8Bytes]] = 1]
    nil
    (raise: 'test-failure "valid?: 'hello' should return 1"))

;; ── valid?: — empty bytes are valid utf-8 ─────────────────────────

(if [[Utf8 valid?: ["" asUtf8Bytes]] = 1]
    nil
    (raise: 'test-failure "valid?: empty bytes should return 1"))

;; ── valid?: — invalid lead byte → 0 ────────────────────────────────
;; 0xFF is not a valid utf-8 lead byte. decode base64 of the
;; single byte 0xFF to get a Bytes value we can pass.
;; base64 of 0xFF is "/w=="

(let ((Base64 [$mco load: "core/base64"]))
  (if [[Utf8 valid?: [Base64 decode: "/w=="]] = 0]
      nil
      (raise: 'test-failure "valid?: byte 0xFF should return 0 (invalid lead)")))

;; ── length: — ascii: 1 byte per codepoint ──────────────────────────

(if [[Utf8 length: ["hello" asUtf8Bytes]] = 5]
    nil
    (raise: 'test-failure "length: 'hello' should be 5 codepoints"))

;; ── length: — empty → 0 ────────────────────────────────────────────

(if [[Utf8 length: ["" asUtf8Bytes]] = 0]
    nil
    (raise: 'test-failure "length: empty should be 0"))

;; ── length: — multi-byte codepoints ────────────────────────────────
;; "café" = 5 codepoints (c-a-f-é, where é is U+00E9, 2 bytes in utf-8).
;; base64 of the utf-8 bytes for "café" = "Y2Fmw6k="

(let ((Base64 [$mco load: "core/base64"]))
  (if [[Utf8 length: [Base64 decode: "Y2Fmw6k="]] = 4]
      nil
      (raise: 'test-failure "length: 'café' should be 4 codepoints")))

;; ── length: — 3-byte codepoint (CJK) ───────────────────────────────
;; U+4E2D (中) encodes as 3 utf-8 bytes: E4 B8 AD.
;; base64 of those 3 bytes = "5Lit"
;; "中文" (2 CJK chars) = 6 bytes, 2 codepoints.
;; base64 of the utf-8 bytes for "中文" = "5Lit5paH"

(let ((Base64 [$mco load: "core/base64"]))
  (if [[Utf8 length: [Base64 decode: "5Lit5paH"]] = 2]
      nil
      (raise: 'test-failure "length: '中文' should be 2 codepoints")))

;; ── valid?: — well-formed multi-byte sequence ───────────────────────
;; "café" should be valid

(let ((Base64 [$mco load: "core/base64"]))
  (if [[Utf8 valid?: [Base64 decode: "Y2Fmw6k="]] = 1]
      nil
      (raise: 'test-failure "valid?: 'café' utf-8 bytes should return 1")))
