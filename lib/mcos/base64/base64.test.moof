;; lib/mcos/base64/base64.test.moof — tests for core/base64 mco.
;;
;; uses raw raise: for failures — no test framework needed.
;;
;; note: moof has no catch/rescue, so the 'base64-decode raise path is
;; tested by the integration runner's wasm_mco.rs Rust tests instead.

(def Base64 [$mco load: "core/base64"])

;; ── decode "aGVsbG8=" → bytes for "hello" ────────────────────────
;; ASCII: h=104 e=101 l=108 l=108 o=111

(let ((b [Base64 decode: "aGVsbG8="]))
  (if [[b length] = 5]
      nil
      (raise: 'test-failure "decode: 'hello' should be 5 bytes"))
  (if [[b at: 0] = 104]
      nil
      (raise: 'test-failure "decode: byte 0 should be 104 ('h')"))
  (if [[b at: 1] = 101]
      nil
      (raise: 'test-failure "decode: byte 1 should be 101 ('e')"))
  (if [[b at: 2] = 108]
      nil
      (raise: 'test-failure "decode: byte 2 should be 108 ('l')"))
  (if [[b at: 3] = 108]
      nil
      (raise: 'test-failure "decode: byte 3 should be 108 ('l')"))
  (if [[b at: 4] = 111]
      nil
      (raise: 'test-failure "decode: byte 4 should be 111 ('o')")))

;; ── encode/decode round-trip ─────────────────────────────────────
;; decode a known string → bytes, re-encode → should match original

(let ((decoded [Base64 decode: "aGVsbG8="]))
  (let ((reencoded [Base64 encode: decoded]))
    (if [reencoded = "aGVsbG8="]
        nil
        (raise: 'test-failure "round-trip: encode(decode('aGVsbG8=')) should equal 'aGVsbG8='"))))

;; ── empty bytes encode to empty string ───────────────────────────

(let ((empty-bytes [Base64 decode: ""])
      (empty-str [Base64 encode: [Base64 decode: ""]]))
  (if [[empty-str length] = 0]
      nil
      (raise: 'test-failure "empty round-trip: encode of empty bytes should be empty string")))

;; ── longer round-trip ─────────────────────────────────────────────
;; "Zm9vYmFy" = base64 for "foobar"

(let ((decoded [Base64 decode: "Zm9vYmFy"]))
  (let ((reencoded [Base64 encode: decoded]))
    (if [reencoded = "Zm9vYmFy"]
        nil
        (raise: 'test-failure "round-trip: encode(decode('Zm9vYmFy')) should equal 'Zm9vYmFy'"))))
