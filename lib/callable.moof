; callable.moof — implement call:, get composition

(def Callable (make-protocol "Callable"
  (list 'call:)
  #[
    'compose: => (fn (self other) (fn (x) (self (other x))))
    '>> => (fn (self other) (fn (x) (other (self x))))
    'partial: => (fn (self arg) (fn (x) (self arg x)))
    'flip => (fn (self) (fn (a b) (self b a)))
  ]
  nil))

(defn id (x) x)
(defn constantly (x) (fn args x))
