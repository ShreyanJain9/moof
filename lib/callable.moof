; callable.moof — implement call:, get composition

(def Callable (make-protocol "Callable"
  (list 'call:)
  #[
    'compose: => (fn (this other) (fn (x) (this (other x))))
    '>> => (fn (this other) (fn (x) (other (this x))))
    'partial: => (fn (this arg) (fn (x) (this arg x)))
    'flip => (fn (this) (fn (a b) (this b a)))
  ]
  nil))

(defn id (x) x)
(defn constantly (x) (fn args x))
